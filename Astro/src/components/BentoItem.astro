---
import { Image } from 'astro:assets';
const { photo, eager = false } = Astro.props;
---

<div class={`relative overflow-hidden rounded-[32px] bg-appleGray-100 dark:bg-appleGray-800 shadow-sm transition-transform duration-500 hover:scale-[1.02] hover:shadow-xl group ${photo.data.span} @container`}>
  <Image 
    src={photo.data.image} 
    alt={photo.data.title} 
    loading={eager ? 'eager' : 'lazy'}
    fetchpriority={eager ? 'high' : 'auto'}
    class="w-full h-full object-cover select-none transition-transform duration-700 group-hover:scale-105"
  />
  
  <!-- Overlay Content -->
  <div class="absolute inset-0 bg-gradient-to-t from-appleGray-900/80 via-appleGray-900/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-6">
    <h3 class="text-white font-semibold text-lg @md:text-xl translate-y-4 group-hover:translate-y-0 transition-transform duration-300 ease-out">{photo.data.title}</h3>
    <div class="flex items-center gap-2 text-appleGray-200 text-sm mt-1 translate-y-4 group-hover:translate-y-0 transition-transform duration-300 delay-75 ease-out">
      {photo.data.location && (
        <span class="flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          {photo.data.location}
        </span>
      )}
      <span class="opacity-50">•</span>
      <span>{photo.data.date}</span>
    </div>
  </div>
</div>
