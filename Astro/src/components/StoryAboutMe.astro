---
// src/components/StoryAboutMe.astro
---
<section class="min-h-screen flex flex-col justify-center items-center px-4 sm:px-6 lg:px-8 py-20 relative bg-appleGray-50 dark:bg-appleGray-950">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-[30%] -right-[10%] w-[70%] h-[70%] rounded-full bg-indigo-200/20 dark:bg-indigo-900/20 blur-3xl"></div>
  </div>
  <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-12 lg:gap-20 z-10">
    <div class="flex-1 space-y-8 animate-fade-in">
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-black tracking-tight leading-tight">
        Hi, I'm <br/><span class="bg-gradient-to-r from-blue-500 to-indigo-500 bg-clip-text text-transparent">Alex</span>.
      </h1>
      <p class="text-xl md:text-2xl text-appleGray-600 dark:text-appleGray-400 font-light leading-relaxed max-w-lg">
        Welcome to my story. I'm a passionate creative who loves to capture life's simple details and grand narratives. 
        Scroll down to walk through the journey of my life.
      </p>
    </div>
    <div class="flex-1 w-full max-w-sm lg:max-w-md animate-slide-up" style="animation-delay: 200ms;">
      <img 
        src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=1000&auto=format&fit=crop" 
        alt="Portrait of Alex" 
        class="zoomable w-full aspect-[4/5] object-cover rounded-3xl shadow-2xl cursor-zoom-in hover:scale-[1.02] transition-transform duration-500"
      />
    </div>
  </div>
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce text-appleGray-400">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
  </div>
</section>
