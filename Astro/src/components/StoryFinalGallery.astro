---
// src/components/StoryFinalGallery.astro
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

const localImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/StoryFinalGallery/*.{jpeg,jpg,png,gif,webp,avif}', { eager: true });
const imageList = Object.values(localImages).map(img => img.default);
const hasLocalImages = imageList.length > 0;

const fallbackImages = [
  "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=800&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1534528741775-53994a69daeb?q=80&w=800&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?q=80&w=800&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1469474968028-56623f02e42e?q=80&w=800&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=800&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1517841905240-472988babdf9?q=80&w=800&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1524504388940-b1c1722653e1?q=80&w=800&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?q=80&w=800&auto=format&fit=crop"
];
---
<section class="py-24 lg:py-32 px-4 sm:px-6 lg:px-8 bg-white dark:bg-appleGray-900 border-t border-appleGray-200 dark:border-appleGray-800">
  <div class="max-w-7xl mx-auto">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">A Few More Moments</h2>
      <p class="text-appleGray-600 dark:text-appleGray-400 font-light">The story continues behind the lens.</p>
    </div>
    <!-- Masonry style -->
    <div class="columns-2 md:columns-3 lg:columns-4 gap-4 space-y-4">
      {hasLocalImages ? (
        imageList.map((img, index) => (
          <Image 
            src={img} 
            alt={`Gallery Moment ${index + 1}`} 
            class="zoomable w-full rounded-2xl cursor-zoom-in shadow-sm hover:shadow-xl transition-shadow break-inside-avoid" 
          />
        ))
      ) : (
        fallbackImages.map((src, index) => (
          <img 
            src={src} 
            alt={`Me Moment ${index + 1}`} 
            class="zoomable w-full rounded-2xl cursor-zoom-in shadow-sm hover:shadow-xl transition-shadow break-inside-avoid" 
          />
        ))
      )}
    </div>
  </div>
</section>
