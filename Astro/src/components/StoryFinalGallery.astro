---
// src/components/StoryFinalGallery.astro
---
<section class="py-24 lg:py-32 px-4 sm:px-6 lg:px-8 bg-white dark:bg-appleGray-900 border-t border-appleGray-200 dark:border-appleGray-800">
  <div class="max-w-7xl mx-auto">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">A Few More Moments</h2>
      <p class="text-appleGray-600 dark:text-appleGray-400 font-light">The story continues behind the lens.</p>
    </div>
    <!-- Masonry style -->
    <div class="columns-2 md:columns-3 lg:columns-4 gap-4 space-y-4">
      <img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=800&auto=format&fit=crop" alt="Me Moment 1" class="zoomable w-full rounded-2xl cursor-zoom-in shadow-sm hover:shadow-xl transition-shadow break-inside-avoid" />
      <img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?q=80&w=800&auto=format&fit=crop" alt="Me Moment 2" class="zoomable w-full rounded-2xl cursor-zoom-in shadow-sm hover:shadow-xl transition-shadow break-inside-avoid" />
      <img src="https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?q=80&w=800&auto=format&fit=crop" alt="Me Moment 3" class="zoomable w-full rounded-2xl cursor-zoom-in shadow-sm hover:shadow-xl transition-shadow break-inside-avoid" />
      <img src="https://images.unsplash.com/photo-1488161628813-04466f8724ce?q=80&w=800&auto=format&fit=crop" alt="Me Moment 4" class="zoomable w-full rounded-2xl cursor-zoom-in shadow-sm hover:shadow-xl transition-shadow break-inside-avoid" />
      <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=800&auto=format&fit=crop" alt="Me Moment 5" class="zoomable w-full rounded-2xl cursor-zoom-in shadow-sm hover:shadow-xl transition-shadow break-inside-avoid" />
      <img src="https://images.unsplash.com/photo-1517841905240-472988babdf9?q=80&w=800&auto=format&fit=crop" alt="Me Moment 6" class="zoomable w-full rounded-2xl cursor-zoom-in shadow-sm hover:shadow-xl transition-shadow break-inside-avoid" />
      <img src="https://images.unsplash.com/photo-1524504388940-b1c1722653e1?q=80&w=800&auto=format&fit=crop" alt="Me Moment 7" class="zoomable w-full rounded-2xl cursor-zoom-in shadow-sm hover:shadow-xl transition-shadow break-inside-avoid" />
      <img src="https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?q=80&w=800&auto=format&fit=crop" alt="Me Moment 8" class="zoomable w-full rounded-2xl cursor-zoom-in shadow-sm hover:shadow-xl transition-shadow break-inside-avoid" />
    </div>
