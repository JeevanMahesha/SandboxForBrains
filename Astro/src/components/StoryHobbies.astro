---
// src/components/StoryHobbies.astro
---
<section class="py-24 lg:py-32 px-4 sm:px-6 lg:px-8 bg-white dark:bg-appleGray-900 border-t border-appleGray-200 dark:border-appleGray-800">
  <div class="max-w-6xl mx-auto">
    <div class="text-center max-w-3xl mx-auto mb-16 lg:mb-24 space-y-6">
      <span class="text-indigo-500 font-semibold tracking-wider uppercase text-sm">Chapter 03</span>
      <h2 class="text-4xl md:text-5xl font-bold">Hobbies & Passions</h2>
      <p class="text-lg md:text-xl text-appleGray-600 dark:text-appleGray-400 leading-relaxed font-light">
        When I'm not working, I love exploring the great outdoors, getting lost in a good book, and capturing street culture through my lens.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      <div class="space-y-4 group">
        <div class="overflow-hidden rounded-2xl shadow-lg">
          <img src="https://images.unsplash.com/photo-1502086223501-7ea6ecd79368?q=80&w=800&auto=format&fit=crop" alt="Hiking" class="zoomable w-full h-80 object-cover cursor-zoom-in group-hover:scale-105 transition-transform duration-500" />
        </div>
        <h3 class="text-xl font-semibold text-center">Hiking</h3>
      </div>
      <div class="space-y-4 group">
        <div class="overflow-hidden rounded-2xl shadow-lg">
          <img src="https://images.unsplash.com/photo-1493711662062-fa541fae0ffe?q=80&w=800&auto=format&fit=crop" alt="Photography" class="zoomable w-full h-80 object-cover cursor-zoom-in group-hover:scale-105 transition-transform duration-500" />
        </div>
        <h3 class="text-xl font-semibold text-center">Photography</h3>
      </div>
      <div class="space-y-4 group">
        <div class="overflow-hidden rounded-2xl shadow-lg">
          <img src="https://images.unsplash.com/photo-1518098268026-4e89f1a2cd8e?q=80&w=800&auto=format&fit=crop" alt="Reading" class="zoomable w-full h-80 object-cover cursor-zoom-in group-hover:scale-105 transition-transform duration-500" />
        </div>
        <h3 class="text-xl font-semibold text-center">Reading</h3>
      </div>
    </div>
  </div>
</section>
