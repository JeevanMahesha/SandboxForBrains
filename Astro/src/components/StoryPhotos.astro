---
// src/components/StoryPhotos.astro
---
<section class="w-full bg-black py-2 lg:py-4">
  <div class="w-full mx-auto px-2 sm:px-4">
    <!-- Broken grid layout for visual interest -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-2 md:gap-4 auto-rows-[200px] md:auto-rows-[300px]">
      <img src="https://images.unsplash.com/photo-1602216056096-3b40cc0c9944?q=80&w=1500&auto=format&fit=crop" alt="Photo Section 1" class="zoomable w-full h-full object-cover cursor-zoom-in md:col-span-2 md:row-span-2 rounded-lg opacity-90 hover:opacity-100 transition-opacity" />
      <img src="https://images.unsplash.com/photo-1605217613423-0a61bd725c8a?q=80&w=800&auto=format&fit=crop" alt="Photo Section 2" class="zoomable w-full h-full object-cover cursor-zoom-in rounded-lg opacity-90 hover:opacity-100 transition-opacity" />
      <img src="https://images.unsplash.com/photo-1593693397321-28d1162463e2?q=80&w=800&auto=format&fit=crop" alt="Photo Section 3" class="zoomable w-full h-full object-cover cursor-zoom-in rounded-lg opacity-90 hover:opacity-100 transition-opacity" />
      <img src="https://images.unsplash.com/photo-1563223126-78b1afc2b740?q=80&w=1000&auto=format&fit=crop" alt="Photo Section 4" class="zoomable w-full h-full object-cover cursor-zoom-in md:col-span-2 rounded-lg opacity-90 hover:opacity-100 transition-opacity" />
    </div>
  </div>
</section>
