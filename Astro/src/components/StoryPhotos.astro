---
// src/components/StoryPhotos.astro
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

const localImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/StoryPhotos/*.{jpeg,jpg,png,gif,webp,avif}', { eager: true });
const imageList = Object.values(localImages).map(img => img.default);
const hasLocalImages = imageList.length > 0;

const fallbackImages = [
  "https://images.unsplash.com/photo-1602216056096-3b40cc0c9944?q=80&w=1500&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1605217613423-0a61bd725c8a?q=80&w=800&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1472396961693-142e6e269027?q=80&w=800&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1454372182658-c712e4c5a1db?q=80&w=1000&auto=format&fit=crop"
];
---
<section class="w-full bg-black py-2 lg:py-4">
  <div class="w-full mx-auto px-2 sm:px-4">
    <!-- Broken grid layout for visual interest -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-2 md:gap-4 auto-rows-[200px] md:auto-rows-[300px]">
      {hasLocalImages ? (
        imageList.map((img, index) => {
          let gridClass = '';
          if (index % 4 === 0) gridClass = 'md:col-span-2 md:row-span-2';
          else if (index % 4 === 3) gridClass = 'md:col-span-2';
          return (
            <Image 
              src={img} 
              alt={`Photo Gallery Image ${index + 1}`} 
              class={`zoomable w-full h-full object-cover cursor-zoom-in rounded-lg opacity-90 hover:opacity-100 transition-opacity ${gridClass}`} 
            />
          );
        })
      ) : (
        fallbackImages.map((src, index) => {
          let gridClass = '';
          if (index === 0) gridClass = 'md:col-span-2 md:row-span-2';
          else if (index === 3) gridClass = 'md:col-span-2';
          return (
            <img 
              src={src} 
              alt={`Photo Section ${index + 1}`} 
              class={`zoomable w-full h-full object-cover cursor-zoom-in rounded-lg opacity-90 hover:opacity-100 transition-opacity ${gridClass}`} 
            />
          );
        })
      )}
    </div>
  </div>
</section>
